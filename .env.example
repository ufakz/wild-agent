# Environment Variables for Wild Agent

# HuggingFace Token (Required for EmbeddingGemma model)
# Get your token from: https://huggingface.co/settings/tokens
# You must accept the EmbeddingGemma license at: https://huggingface.co/google/embeddinggemma-300m
HF_TOKEN=your_huggingface_token_here

# Optional: Set to specify device (cpu, cuda, mps)
# DEVICE=auto
